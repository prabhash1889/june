{
  "name": "june",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A local-first voice agent that controls the SAPLE ecosystem (and more) by voice.",
  "scripts": {
    "dev": "vite",
    "fetch-models": "node scripts/fetch-models.mjs",
    "predev": "node scripts/fetch-models.mjs",
    "prebuild": "node scripts/fetch-models.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p mcp/saple-bridge-control/tsconfig.json && tsc --noEmit -p mcp/files/tsconfig.json && tsc --noEmit -p mcp/memory/tsconfig.json && tsc --noEmit -p agent/tsconfig.json",
    "agent": "tsx agent/cli.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@tauri-apps/api": "^2",
    "onnxruntime-web": "^1.27.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "tsx": "^4.23.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
